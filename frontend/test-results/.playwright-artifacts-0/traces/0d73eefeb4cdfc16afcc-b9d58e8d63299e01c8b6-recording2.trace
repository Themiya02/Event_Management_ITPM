{"type":"frame-snapshot","snapshot":{"callId":"call@70","snapshotName":"after@call@70","pageId":"page@302e49127fd5800eb643e61b26b76897","frameId":"frame@d297bafd2fe5735f960b987be8627256","frameUrl":"http://localhost:5173/login","doctype":"html","html":["HTML",{"lang":"en"},["HEAD",{},["BASE",{"href":"http://localhost:5173/login"}],"\n    ","\n\n    ","\n\n    ",["META",{"charset":"utf-8"}],"\n    ",["LINK",{"rel":"icon","type":"image/png","href":"/logo.png"}],"\n    ",["META",{"name":"viewport","content":"width=device-width, initial-scale=1.0"}],"\n    ",["TITLE",{},"Eventio"],"\n    ",["LINK",{"rel":"preconnect","href":"https://fonts.googleapis.com"}],"\n    ",["LINK",{"rel":"preconnect","href":"https://fonts.gstatic.com","crossorigin":""}],"\n    ",["LINK",{"href":"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800&family=Poppins:wght@300;400;500;600;700&family=Great+Vibes&family=Playfair+Display:wght@400;700;900&display=swap","rel":"stylesheet"}],"\n  ",["STYLE",{},"@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;600;700;800&display=swap');\r\n\r\n:root {\r\n  /* Core Color Palette - Light Theme */\r\n  --bg-color: #F8FAFC;\r\n  --surface-color: #FFFFFF;\r\n  --surface-color-hover: #F1F5F9;\r\n  --primary-color: #2563eb;\r\n  /* Royal Blue */\r\n  --primary-color-hover: #1d4ed8;\r\n  --primary-gradient: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);\r\n  --secondary-color: #10B981;\r\n  --accent-color: #EF4444;\r\n\r\n  /* Text */\r\n  --text-main: #0F172A;\r\n  --text-muted: #64748B;\r\n  --text-dark: #FFFFFF;\r\n  /* Inverted for buttons */\r\n\r\n  /* Borders and UI */\r\n  --border-color: rgba(255, 255, 255, 0.4);\r\n  /* Enhanced frosted border */\r\n  --glass-bg: rgba(255, 255, 255, 0.55);\r\n  /* Luminous high-translucency glass */\r\n  --glass-border: rgba(255, 255, 255, 0.8);\r\n  --glass-shadow: 0 12px 40px 0 rgba(31, 38, 135, 0.15);\r\n\r\n  /* Shadows */\r\n  --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.05), 0 1px 2px rgba(0, 0, 0, 0.03);\r\n  --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.03);\r\n  --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -4px rgba(0, 0, 0, 0.03);\r\n  --shadow-neon: 0 0 15px rgba(147, 51, 234, 0.3);\r\n\r\n  /* Dimensions */\r\n  --sidebar-width: 260px;\r\n  --topbar-height: 80px;\r\n\r\n  /* Transitions */\r\n  --transition-fast: 0.15s cubic-bezier(0.4, 0, 0.2, 1);\r\n  --transition-normal: 0.3s cubic-bezier(0.4, 0, 0.2, 1);\r\n  --transition-bounce: 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);\r\n}\r\n\r\n* {\r\n  box-sizing: border-box;\r\n  margin: 0;\r\n  padding: 0;\r\n}\r\n\r\nhtml {\r\n  font-size: 16px;\r\n}\r\n\r\nbody {\r\n  font-family: 'Inter', sans-serif;\r\n  background-color: #f8fafc;\r\n  background-image:\r\n    radial-gradient(at 40% 20%, hsla(210, 100%, 94%, 0.7) 0px, transparent 50%),\r\n    radial-gradient(at 80% 0%, hsla(220, 100%, 92%, 0.7) 0px, transparent 50%),\r\n    radial-gradient(at 0% 50%, hsla(200, 100%, 94%, 0.7) 0px, transparent 50%),\r\n    radial-gradient(at 80% 50%, hsla(215, 100%, 92%, 0.7) 0px, transparent 50%),\r\n    radial-gradient(at 0% 100%, hsla(225, 100%, 94%, 0.7) 0px, transparent 50%),\r\n    radial-gradient(at 80% 100%, hsla(205, 100%, 92%, 0.7) 0px, transparent 50%),\r\n    radial-gradient(at 0% 0%, hsla(210, 100%, 97%, 0.7) 0px, transparent 50%);\r\n  background-attachment: fixed;\r\n  color: var(--text-main);\r\n  -webkit-font-smoothing: antialiased;\r\n  -moz-osx-font-smoothing: grayscale;\r\n  min-height: 100vh;\r\n}\r\n\r\nh1,\r\nh2,\r\nh3,\r\nh4,\r\nh5,\r\nh6 {\r\n  font-family: 'Outfit', sans-serif;\r\n  font-weight: 600;\r\n  letter-spacing: -0.02em;\r\n  color: var(--text-main);\r\n}\r\n\r\nbutton {\r\n  cursor: pointer;\r\n  font-family: 'Inter', sans-serif;\r\n  border: none;\r\n  background: none;\r\n  outline: none;\r\n  transition: all var(--transition-normal);\r\n}\r\n\r\na {\r\n  text-decoration: none;\r\n  color: inherit;\r\n  transition: color var(--transition-normal);\r\n}\r\n\r\nul,\r\nol {\r\n  list-style: none;\r\n}\r\n\r\n/* Utilities */\r\n\r\n.glass-panel {\r\n  background: var(--glass-bg);\r\n  backdrop-filter: blur(24px) saturate(180%);\r\n  -webkit-backdrop-filter: blur(24px) saturate(180%);\r\n  border: 1px solid var(--border-color);\r\n  border-radius: 20px;\r\n  box-shadow: var(--glass-shadow);\r\n  transition: box-shadow 0.4s ease, transform 0.4s ease;\r\n}\r\n\r\n.glass-panel:hover {\r\n  box-shadow: 0 15px 45px 0 rgba(31, 38, 135, 0.2);\r\n}\r\n\r\n.text-gradient {\r\n  background: var(--primary-gradient);\r\n  -webkit-background-clip: text;\r\n  -webkit-text-fill-color: transparent;\r\n  background-clip: text;\r\n}\r\n\r\n/* =========================================\r\n   GLOBAL EVENT CARD COMPONENT\r\n   ========================================= */\r\n\r\n.events-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\r\n  gap: 2rem;\r\n  margin-top: 1.5rem;\r\n}\r\n\r\n.event-card {\r\n  display: flex;\r\n  flex-direction: column;\r\n  overflow: hidden;\r\n  border-radius: 16px;\r\n  transition: transform 0.3s ease, box-shadow 0.3s ease;\r\n  height: 100%;\r\n  background: var(--surface-bg, #fff);\r\n  border: 1px solid var(--border-color, #e5e7eb);\r\n}\r\n\r\n.event-card:hover {\r\n  transform: translateY(-5px);\r\n  box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);\r\n}\r\n\r\n.card-img-wrapper {\r\n  position: relative;\r\n  height: 180px;\r\n  width: 100%;\r\n  overflow: hidden;\r\n  background: var(--primary-gradient);\r\n}\r\n\r\n.card-img-wrapper img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n  transition: transform 0.5s ease;\r\n}\r\n\r\n.event-card:hover .card-img-wrapper img {\r\n  transform: scale(1.05);\r\n}\r\n\r\n.placeholder-img {\r\n  width: 100%;\r\n  height: 100%;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  background: var(--primary-gradient);\r\n  color: white;\r\n  font-size: 3rem;\r\n  opacity: 0.8;\r\n}\r\n\r\n.reg-badge {\r\n  position: absolute;\r\n  top: 1rem;\r\n  right: 1rem;\r\n  padding: 0.4rem 0.8rem;\r\n  border-radius: 20px;\r\n  font-size: 0.75rem;\r\n  font-weight: 600;\r\n  text-transform: uppercase;\r\n  letter-spacing: 0.5px;\r\n  backdrop-filter: blur(10px);\r\n  -webkit-backdrop-filter: blur(10px);\r\n  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);\r\n}\r\n\r\n.reg-badge.open {\r\n  background: rgba(167, 139, 250, 0.8);\r\n  color: white;\r\n  border: 1px solid rgba(255, 255, 255, 0.2);\r\n}\r\n\r\n.reg-badge.required {\r\n  background: rgba(244, 63, 94, 0.8);\r\n  color: white;\r\n  border: 1px solid rgba(255, 255, 255, 0.2);\r\n}\r\n\r\n.card-content {\r\n  padding: 1.5rem;\r\n  display: flex;\r\n  flex-direction: column;\r\n  flex-grow: 1;\r\n}\r\n\r\n.card-content h3 {\r\n  margin: 0 0 0.5rem 0;\r\n  font-size: 1.3rem;\r\n  color: var(--text-color, #111827);\r\n  line-height: 1.3;\r\n}\r\n\r\n.org-name {\r\n  font-size: 0.85rem;\r\n  color: var(--text-muted, #6b7280);\r\n  margin-bottom: 1rem;\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 0.4rem;\r\n}\r\n\r\n.card-details {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 0.5rem;\r\n  margin-bottom: 1.5rem;\r\n  font-size: 0.9rem;\r\n  color: var(--text-color, #374151);\r\n}\r\n\r\n.detail-item {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 0.5rem;\r\n}\r\n\r\n.card-actions {\r\n  margin-top: auto;\r\n  border-top: 1px solid var(--border-color, #e5e7eb);\r\n  padding-top: 1rem;\r\n}\r\n\r\n.btn-view-event {\r\n  width: 100%;\r\n  padding: 0.75rem;\r\n  border-radius: 8px;\r\n  border: none;\r\n  background: var(--primary-color);\r\n  color: white;\r\n  font-weight: 600;\r\n  cursor: pointer;\r\n  transition: opacity 0.2s;\r\n  text-align: center;\r\n  text-decoration: none;\r\n  display: inline-block;\r\n}\r\n\r\n.btn-view-event:hover {\r\n  opacity: 0.9;\r\n  background: var(--primary-color-hover);\r\n}\r\n\r\n/* =========================================\r\n   GLOBAL PREMIUM SEARCH BAR\r\n   ========================================= */\r\n\r\n.ud-search-wrapper {\r\n  position: relative;\r\n  z-index: 1;\r\n  display: flex;\r\n  justify-content: center;\r\n  width: 100%;\r\n}\r\n\r\n.ud-search-bar {\r\n  display: flex;\r\n  align-items: center;\r\n  background: white;\r\n  border-radius: 50px;\r\n  padding: 6px 6px 6px 1.5rem;\r\n  width: 100%;\r\n  max-width: 680px;\r\n  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);\r\n  gap: 0.75rem;\r\n  transition: box-shadow 0.3s ease, transform 0.3s ease;\r\n}\r\n\r\n.ud-search-bar:focus-within {\r\n  box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);\r\n  transform: translateY(-2px);\r\n}\r\n\r\n.ud-search-category {\r\n  color: var(--primary-color);\r\n  font-weight: 700;\r\n  font-size: 0.9rem;\r\n  white-space: nowrap;\r\n  padding-right: 1rem;\r\n  border-right: 2px solid #e5e7eb;\r\n}\r\n\r\n.ud-search-bar input {\r\n  flex: 1;\r\n  border: none;\r\n  outline: none;\r\n  font-size: 1rem;\r\n  color: #111827;\r\n  background: transparent;\r\n  padding: 0.5rem 0;\r\n  min-width: 0;\r\n}\r\n\r\n.ud-search-bar input::placeholder {\r\n  color: #9ca3af;\r\n}\r\n\r\n.ud-search-btn {\r\n  background: var(--primary-gradient);\r\n  color: white;\r\n  border: none;\r\n  border-radius: 50px;\r\n  padding: 0.65rem 1.5rem;\r\n  font-size: 0.9rem;\r\n  font-weight: 600;\r\n  cursor: pointer;\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 0.5rem;\r\n  transition: all 0.2s ease;\r\n  white-space: nowrap;\r\n  flex-shrink: 0;\r\n}\r\n\r\n.ud-search-btn:hover {\r\n  background: var(--primary-color-hover);\r\n  box-shadow: 0 6px 15px rgba(37, 99, 235, 0.4);\r\n}\r\n\r\n/* =========================================\r\n   GLOWING PREMIUM SEARCH BAR (DARK/BLUE GLOW)\r\n   ========================================= */\r\n\r\n.glowing-search-wrapper {\r\n  position: relative;\r\n  z-index: 10;\r\n  display: flex;\r\n  justify-content: center;\r\n  width: 100%;\r\n  margin: 2rem auto 0 auto;\r\n  /* Inside hero banner */\r\n}\r\n\r\n.glowing-search-bar {\r\n  display: flex;\r\n  align-items: center;\r\n  background: #0f172a;\r\n  border-radius: 50px;\r\n  padding: 6px 6px 6px 1.5rem;\r\n  width: 100%;\r\n  max-width: 700px;\r\n  border: 1px solid rgba(255, 255, 255, 0.1);\r\n  box-shadow: 0 0 25px rgba(37, 99, 235, 0.5), 0 0 50px rgba(37, 99, 235, 0.3);\r\n  gap: 0.75rem;\r\n  transition: box-shadow 0.3s ease, transform 0.3s ease;\r\n}\r\n\r\n.glowing-search-bar:focus-within {\r\n  box-shadow: 0 0 35px rgba(37, 99, 235, 0.7), 0 0 60px rgba(37, 99, 235, 0.4);\r\n  transform: translateY(-2px);\r\n}\r\n\r\n.glowing-search-icon {\r\n  color: white;\r\n  opacity: 0.8;\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n\r\n.glowing-search-bar input {\r\n  flex: 1;\r\n  border: none;\r\n  outline: none;\r\n  font-size: 1.1rem;\r\n  color: white;\r\n  background: transparent;\r\n  padding: 0.8rem 0;\r\n  min-width: 0;\r\n}\r\n\r\n.glowing-search-bar input::placeholder {\r\n  color: rgba(255, 255, 255, 0.5);\r\n}\r\n\r\n.glowing-search-btn {\r\n  background: rgba(255, 255, 255, 0.1);\r\n  color: white;\r\n  border: 1px solid rgba(255, 255, 255, 0.1);\r\n  border-radius: 50%;\r\n  width: 48px;\r\n  height: 48px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  cursor: pointer;\r\n  transition: all 0.2s ease;\r\n  flex-shrink: 0;\r\n}\r\n\r\n.glowing-search-btn:hover {\r\n  background: var(--primary-gradient);\r\n  border-color: transparent;\r\n  box-shadow: 0 0 15px rgba(37, 99, 235, 0.8);\r\n}"],["STYLE",{},"@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');\r\n\r\nbody {\r\n    margin: 0;\r\n    font-family: 'Poppins', sans-serif;\r\n}\r\n\r\n.auth-container {\r\n    min-height: 100vh;\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: center;\r\n    background: #2a73a9; /* Solid blue matching the reference */\r\n    padding: 2rem;\r\n    position: relative;\r\n    overflow: hidden;\r\n}\r\n\r\n/* Page Entry Animation */\r\n\r\n.page-transition-enter {\r\n    animation: pageEnter 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;\r\n}\r\n\r\n@keyframes pageEnter {\r\n    0% {\r\n        opacity: 0;\r\n        transform: scale(0.95) translateY(30px);\r\n    }\r\n    100% {\r\n        opacity: 1;\r\n        transform: scale(1) translateY(0);\r\n    }\r\n}\r\n\r\n/* The Main Split Card */\r\n\r\n.auth-card {\r\n    width: 100%;\r\n    max-width: 900px;\r\n    background: #ffffff;\r\n    border-radius: 12px;\r\n    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);\r\n    display: flex;\r\n    overflow: hidden;\r\n    position: relative;\r\n    z-index: 10;\r\n    min-height: 550px;\r\n}\r\n\r\n/* Left Image Pane */\r\n\r\n.auth-image-pane {\r\n    flex: 1;\r\n    position: relative;\r\n    background-image: url('https://images.unsplash.com/photo-1540575467063-178a50c2df87?q=80&w=2070&auto=format&fit=crop'); /* Event crowd image */\r\n    background-size: cover;\r\n    background-position: center;\r\n    display: flex;\r\n    flex-direction: column;\r\n    justify-content: space-between;\r\n    padding: 3rem 2rem;\r\n    color: white;\r\n    text-align: center;\r\n}\r\n\r\n.auth-image-pane::before {\r\n    content: '';\r\n    position: absolute;\r\n    top: 0; left: 0; width: 100%; height: 100%;\r\n    background: rgba(0, 0, 0, 0.5); /* Dark overlay */\r\n    z-index: 1;\r\n}\r\n\r\n.auth-image-content {\r\n    position: relative;\r\n    z-index: 2;\r\n    display: flex;\r\n    flex-direction: column;\r\n    align-items: center;\r\n    gap: 1rem;\r\n}\r\n\r\n.auth-image-icon {\r\n    width: 40px;\r\n    height: 40px;\r\n    color: #60a5fa; /* Light blue icon */\r\n}\r\n\r\n.auth-image-title {\r\n    font-size: 2.5rem;\r\n    font-weight: 800;\r\n    line-height: 1.2;\r\n    margin: 0;\r\n    color: #ffffff;\r\n    text-shadow: 0 2px 10px rgba(0,0,0,0.5);\r\n}\r\n\r\n.auth-image-footer {\r\n    position: relative;\r\n    z-index: 2;\r\n    font-size: 0.95rem;\r\n    font-weight: 500;\r\n    line-height: 1.6;\r\n    color: #ffffff;\r\n    text-shadow: 0 1px 5px rgba(0,0,0,0.5);\r\n}\r\n\r\n/* Right Form Pane */\r\n\r\n.auth-form-pane {\r\n    flex: 1.2;\r\n    padding: 3rem;\r\n    display: flex;\r\n    flex-direction: column;\r\n    justify-content: center;\r\n}\r\n\r\n.auth-header {\r\n    text-align: center;\r\n    margin-bottom: 2rem;\r\n}\r\n\r\n.auth-header h2 {\r\n    font-size: 1.8rem;\r\n    font-weight: 700;\r\n    color: #111827;\r\n    margin: 0;\r\n}\r\n\r\n.auth-subtitle {\r\n    font-size: 0.9rem;\r\n    color: #6b7280;\r\n    margin-top: 0.5rem;\r\n}\r\n\r\n.auth-error-box {\r\n    background: #fee2e2;\r\n    color: #dc2626;\r\n    padding: 0.8rem 1rem;\r\n    border-radius: 8px;\r\n    margin-bottom: 1.5rem;\r\n    font-size: 0.85rem;\r\n    text-align: center;\r\n    font-weight: 500;\r\n}\r\n\r\n.auth-form {\r\n    display: flex;\r\n    flex-direction: column;\r\n    gap: 1.25rem;\r\n}\r\n\r\n.input-group {\r\n    display: flex;\r\n    flex-direction: column;\r\n    gap: 0.4rem;\r\n}\r\n\r\n.input-group label {\r\n    font-size: 0.8rem;\r\n    font-weight: 600;\r\n    color: #374151;\r\n}\r\n\r\n.input-group input, \r\n.input-group select {\r\n    width: 100%;\r\n    padding: 0.8rem 1rem;\r\n    font-size: 0.9rem;\r\n    color: #111827;\r\n    background: #ffffff;\r\n    border: 1px solid #d1d5db;\r\n    border-radius: 8px;\r\n    transition: all 0.2s;\r\n    font-family: 'Poppins', sans-serif;\r\n    box-sizing: border-box;\r\n}\r\n\r\n.input-group input::placeholder {\r\n    color: #9ca3af;\r\n    font-weight: 400;\r\n}\r\n\r\n.input-group input:focus,\r\n.input-group select:focus {\r\n    outline: none;\r\n    border-color: #2a73a9;\r\n    box-shadow: 0 0 0 3px rgba(42, 115, 169, 0.1);\r\n}\r\n\r\n.input-group select {\r\n    cursor: pointer;\r\n}\r\n\r\n.auth-extras {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    font-size: 0.85rem;\r\n    color: #4b5563;\r\n}\r\n\r\n.auth-btn {\r\n    width: 100%;\r\n    padding: 0.9rem;\r\n    margin-top: 1rem;\r\n    border-radius: 8px;\r\n    border: none;\r\n    background: #2a73a9; /* Blue button */\r\n    color: white;\r\n    font-size: 1rem;\r\n    font-weight: 600;\r\n    cursor: pointer;\r\n    transition: background 0.3s;\r\n    font-family: inherit;\r\n}\r\n\r\n.auth-btn:hover:not(:disabled) {\r\n    background: #1e5a87;\r\n}\r\n\r\n.auth-btn:disabled {\r\n    opacity: 0.7;\r\n    cursor: not-allowed;\r\n}\r\n\r\n.auth-footer {\r\n    margin-top: 2rem;\r\n    text-align: center;\r\n    font-size: 0.9rem;\r\n    color: #4b5563;\r\n}\r\n\r\n.auth-footer a {\r\n    color: #2a73a9;\r\n    font-weight: 600;\r\n    text-decoration: none;\r\n    margin-left: 0.3rem;\r\n}\r\n\r\n.auth-footer a:hover {\r\n    text-decoration: underline;\r\n}\r\n\r\n/* Responsive */\r\n\r\n@media (max-width: 800px) {\r\n    .auth-card {\r\n        flex-direction: column;\r\n        max-width: 500px;\r\n    }\r\n    .auth-image-pane {\r\n        min-height: 200px;\r\n        padding: 2rem;\r\n    }\r\n    .auth-form-pane {\r\n        padding: 2rem;\r\n    }\r\n}\r\n"],["STYLE",{},".user-dashboard {\r\n  padding: 1rem;\r\n}\r\n\r\n.feed-header {\r\n  margin-bottom: 2rem;\r\n}\r\n\r\n.events-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\r\n  gap: 2rem;\r\n  margin-top: 1.5rem;\r\n}\r\n\r\n.event-card {\r\n  display: flex;\r\n  flex-direction: column;\r\n  overflow: hidden;\r\n  border-radius: 16px;\r\n  transition: transform 0.3s ease, box-shadow 0.3s ease;\r\n  height: 100%;\r\n}\r\n\r\n.event-card:hover {\r\n  transform: translateY(-5px);\r\n  box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);\r\n}\r\n\r\n.card-img-wrapper {\r\n  position: relative;\r\n  height: 180px;\r\n  width: 100%;\r\n  overflow: hidden;\r\n  background: var(--surface-