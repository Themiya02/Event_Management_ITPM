;\r\n  background: var(--glass-bg);\r\n  backdrop-filter: blur(24px);\r\n  -webkit-backdrop-filter: blur(24px);\r\n  box-shadow: var(--shadow-sm);\r\n\r\n  margin-bottom: 20px;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n/* Landing Page Specific Navbar Theme */\r\n.global-navbar.landing-nav {\r\n  background: rgba(15, 23, 42, 0.9) !important;\r\n  backdrop-filter: blur(30px) !important;\r\n  border-bottom: 1px solid rgba(255, 255, 255, 0.15) !important;\r\n}\r\n\r\n.global-navbar.landing-nav .nav-link {\r\n  color: rgba(255, 255, 255, 0.8) !important;\r\n}\r\n\r\n.global-navbar.landing-nav .nav-link.active {\r\n  color: #60a5fa !important;\r\n  font-weight: 700;\r\n}\r\n\r\n.global-navbar.landing-nav .nav-link:hover {\r\n  color: #ffffff !important;\r\n}\r\n\r\n.global-navbar.landing-nav .profile-info {\r\n  background: rgba(255, 255, 255, 0.08) !important;\r\n  border: 1px solid rgba(255, 255, 255, 0.1) !important;\r\n}\r\n\r\n.global-navbar.landing-nav .profile-info:hover {\r\n  background: rgba(255, 255, 255, 0.15) !important;\r\n  border-color: #60a5fa !important;\r\n}\r\n\r\n.global-navbar.landing-nav .profile-role {\r\n  color: rgba(255, 255, 255, 0.6) !important;\r\n}\r\n\r\n.navbar-left {\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n\r\n.profile-info {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n\r\n  background: rgba(255, 255, 255, 0.05);\r\n\r\n  padding: 8px 16px;\r\n  border-radius: 30px;\r\n  border: 1px solid var(--border-color);\r\n  box-shadow: var(--shadow-sm);\r\n\r\n  transition: all 0.3s ease;\r\n  user-select: none;\r\n}\r\n\r\n.profile-info:hover {\r\n  background: rgba(255, 255, 255, 0.1);\r\n  border-color: var(--primary-color);\r\n\r\n}\r\n\r\n.profile-icon {\r\n  font-size: 1.5rem;\r\n  background: var(--primary-gradient);\r\n  -webkit-background-clip: text;\r\n  -webkit-text-fill-color: transparent;\r\n  background-clip: text;\r\n}\r\n\r\n.profile-details {\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n\r\n.profile-name {\r\n  font-weight: 600;\r\n  font-size: 0.95rem;\r\n  color: var(--text-main);\r\n  line-height: 1.2;\r\n}\r\n\r\n.profile-role {\r\n  font-size: 0.8rem;\r\n  font-weight: 500;\r\n  color: var(--primary-color);\r\n  text-transform: uppercase;\r\n  letter-spacing: 0.05em;\r\n}\r\n\r\n\r\n.profile-container {\r\n  position: relative;\r\n}\r\n\r\n.dropdown-arrow {\r\n  color: var(--text-muted);\r\n  font-size: 0.8rem;\r\n  transition: transform 0.3s ease;\r\n}\r\n\r\n.dropdown-arrow.open {\r\n  transform: rotate(180deg);\r\n}\r\n\r\n.navbar-dropdown {\r\n  position: absolute;\r\n  top: calc(100% + 10px);\r\n  right: 0;\r\n  width: 200px;\r\n  background: var(--glass-bg);\r\n  backdrop-filter: blur(20px);\r\n  -webkit-backdrop-filter: blur(20px);\r\n  border-radius: 12px;\r\n  border: 1px solid var(--border-color);\r\n  box-shadow: var(--shadow-lg);\r\n  padding: 8px;\r\n  z-index: 1001;\r\n  display: flex;\r\n  flex-direction: column;\r\n  animation: dropdownFade 0.2s ease-out;\r\n}\r\n\r\n@keyframes dropdownFade {\r\n  from {\r\n    opacity: 0;\r\n    transform: translateY(-10px);\r\n  }\r\n\r\n  to {\r\n    opacity: 1;\r\n    transform: translateY(0);\r\n  }\r\n}\r\n\r\n.dropdown-item {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 10px;\r\n  padding: 10px 15px;\r\n  border-radius: 8px;\r\n  color: var(--text-main);\r\n  text-decoration: none;\r\n  font-size: 0.95rem;\r\n  transition: all 0.2s ease;\r\n  background: transparent;\r\n  border: none;\r\n  width: 100%;\r\n  text-align: left;\r\n  cursor: pointer;\r\n}\r\n\r\n.dropdown-item:hover {\r\n  background: rgba(255, 255, 255, 0.1);\r\n  color: var(--primary-color);\r\n}\r\n\r\n.logout-item:hover {\r\n  background: rgba(239, 68, 68, 0.1);\r\n  color: #ef4444;\r\n}\r\n\r\n.dropdown-divider {\r\n  height: 1px;\r\n  background: var(--border-color);\r\n  margin: 8px 0;\r\n}\r\n\r\n.item-icon {\r\n  font-size: 1.1rem;\r\n}\r\n\r\n.login-btn {\r\n  margin-left: 15px;\r\n  font-size: 0.9rem;\r\n  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);\r\n  color: white !important;\r\n  padding: 8px 20px !important;\r\n  border-radius: 50px;\r\n  font-weight: 700;\r\n  box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);\r\n  text-decoration: none !important;\r\n}\r\n\r\n.login-btn:hover {\r\n  transform: translateY(-1px);\r\n  box-shadow: 0 6px 16px rgba(59, 130, 246, 0.5);\r\n  background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);\r\n  opacity: 1 !important;\r\n}\r\n\r\n.login-btn::after {\r\n  display: none !important;\r\n}\r\n\r\n\r\n.navbar-right {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 40px;\r\n}\r\n\r\n.nav-links {\r\n  display: flex;\r\n  gap: 24px;\r\n}\r\n\r\n.nav-link {\r\n  font-weight: 500;\r\n  color: var(--text-main);\r\n  font-size: 0.95rem;\r\n  position: relative;\r\n  padding: 5px 0;\r\n}\r\n\r\n\r\n.nav-link:hover {\r\n\r\n  color: var(--primary-color);\r\n}\r\n\r\n.nav-link::after {\r\n  content: '';\r\n  position: absolute;\r\n  width: 0;\r\n  height: 2px;\r\n  bottom: 0;\r\n  left: 0;\r\n  background: var(--primary-gradient);\r\n  transition: width var(--transition-normal);\r\n  border-radius: 2px;\r\n}\r\n\r\n\r\n.nav-link:hover::after,\r\n.nav-link.active::after {\r\n  width: 100%;\r\n}\r\n\r\n.nav-link.active {\r\n  color: var(--primary-color);\r\n  font-weight: 700;\r\n}\r\n\r\n.navbar-brand {\r\n  font-family: 'Outfit', sans-serif;\r\n  font-weight: 800;\r\n  font-size: 1.8rem;\r\n  letter-spacing: -0.02em;\r\n  text-transform: uppercase;\r\n\r\n}"],["STYLE",{},".global-footer {\n  margin-top: 40px;\n  padding: 40px 0 0 0;\n  border-radius: 0;\n  border-top: 1px solid var(--border-color);\n  background: var(--glass-bg);\n  backdrop-filter: blur(24px);\n  -webkit-backdrop-filter: blur(24px);\n  width: 100%;\n}\n\n.footer-content {\n  display: flex;\n  justify-content: space-between;\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 0 40px 40px 40px;\n  gap: 40px;\n}\n\n.footer-left {\n  max-width: 350px;\n}\n\n.footer-brand {\n  font-size: 2rem;\n  margin-bottom: 15px;\n  font-family: 'Outfit', sans-serif;\n  font-weight: 800;\n}\n\n.footer-tagline {\n  color: var(--text-muted);\n  font-size: 1rem;\n  line-height: 1.6;\n  margin-bottom: 25px;\n}\n\n.social-links {\n  display: flex;\n  gap: 15px;\n}\n\n.social-icon {\n  font-size: 1.5rem;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 45px;\n  height: 45px;\n  background: rgba(255, 255, 255, 0.6);\n  border: 1px solid var(--border-color);\n  border-radius: 50%;\n  transition: all var(--transition-normal);\n  text-decoration: none;\n}\n\n.social-icon:hover {\n  transform: translateY(-5px);\n  box-shadow: var(--shadow-neon);\n  border-color: var(--primary-color);\n}\n\n.footer-right {\n  display: flex;\n  flex-direction: column;\n}\n\n.footer-heading {\n  font-family: 'Outfit', sans-serif;\n  color: var(--text-main);\n  font-size: 1.2rem;\n  margin-bottom: 20px;\n  position: relative;\n  display: inline-block;\n  padding-bottom: 8px;\n}\n\n.footer-heading::after {\n  content: '';\n  position: absolute;\n  left: 0;\n  bottom: 0;\n  height: 3px;\n  width: 40px;\n  background: var(--primary-gradient);\n  border-radius: 2px;\n}\n\n.faculty-list {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n}\n\n.faculty-list li {\n  color: var(--text-muted);\n  font-weight: 500;\n  transition: color var(--transition-normal);\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n}\n\n.faculty-list li::before {\n  content: '→';\n  color: var(--primary-color);\n  margin-right: 8px;\n  font-weight: bold;\n  opacity: 0;\n  transform: translateX(-10px);\n  transition: all var(--transition-normal);\n}\n\n.faculty-list li:hover {\n  color: var(--primary-color);\n}\n\n.faculty-list li:hover::before {\n  opacity: 1;\n  transform: translateX(0);\n}\n\n.footer-bottom {\n  text-align: center;\n  padding: 20px;\n  border-top: 1px solid var(--border-color);\n  color: var(--text-muted);